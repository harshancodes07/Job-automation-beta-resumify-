# Resumify API Keys — copy this to .env and fill in your values

# Google Gemini (required) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# JSearch via RapidAPI (required) — get from https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Adzuna (optional, Phase 3 fallback) — get from https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Jooble (optional, Phase 3 fallback) — get from https://jooble.org/api/about
JOOBLE_API_KEY=

# Provider config
JOB_PROVIDER=jsearch
JOB_PROVIDER_FALLBACKS=adzuna,jooble
